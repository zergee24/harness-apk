{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness APK Provider Capability Catalog",
  "type": "object",
  "required": ["schemaVersion", "catalogVersion", "providers"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "catalogVersion": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string" },
    "providers": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider" }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "required": ["providerId", "displayName", "defaultModelId", "models"],
      "properties": {
        "providerId": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string" },
        "defaultModelId": { "type": "string", "minLength": 1 },
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/model" }
        }
      }
    },
    "model": {
      "type": "object",
      "required": ["modelId", "contextWindowTokens"],
      "properties": {
        "modelId": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "contextWindowTokens": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "defaultCompressionThresholdPercent": { "type": "integer", "minimum": 1, "maximum": 95 },
        "inputModalities": { "type": "array", "items": { "type": "string" } },
        "outputModalities": { "type": "array", "items": { "type": "string" } },
        "supportsStreaming": { "type": "boolean" },
        "supportsReasoningEffort": { "type": "boolean" },
        "reasoningEffortOptions": { "type": "array", "items": { "type": "string" } },
        "defaultReasoningEffort": { "type": "string" },
        "webSearch": {
          "type": "object",
          "properties": {
            "mode": { "type": "string" },
            "defaultEnabled": { "type": "boolean" }
          }
        },
        "timeouts": {
          "type": "object",
          "properties": {
            "connectMs": { "type": "integer", "minimum": 1 },
            "readMs": { "type": "integer", "minimum": 1 },
            "writeMs": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
